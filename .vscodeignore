# Ce qui NE doit PAS partir dans le .vsix (on ne garde que le runtime :
# extension.js, storage.js, media/, python/, package.json, readme.md).

# Graphe de connaissances graphify + memoire (outillage interne, hors runtime)
graphify-out/**
memory/**

# Brouillons de travail et docs internes
.superpowers/**
docs/**
.claude/**

# Outillage / config dev
.vscode/**
.gitignore
.gitattributes
.git/**
**/.DS_Store

# Tests et doc destinee aux contributeurs (inutiles a l'execution)
test/**
CLAUDE.md

# Artefacts Python
**/__pycache__/**
**/*.py[cod]

# Ne pas empaqueter un .vsix dans le .vsix
*.vsix

# Brouillons / maquettes / outils de montage / enregistrements (hors runtime)
tools/**
tmp/**
*.mp4
montage.py
montage_exemple.md
_preview_mockup.html
_toolbar_variants.html
ig_*.png
